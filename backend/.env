# ── AgriPredict local .env ────────────────────────────────────────────────
# Copy this file to backend/.env and fill in YOUR MySQL password.
# Never commit this file with real credentials.

# Flask
SECRET_KEY=agripredict-secret-key-2026
DEBUG=True

# MySQL  ← change MYSQL_PASSWORD to your local MySQL root password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=agri_predict

# Admin account (created automatically on first run)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_SECRET=AGRI2026

# CORS
CORS_ORIGINS=*
