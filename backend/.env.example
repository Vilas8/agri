# ============================================
# AgriPredict Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-string

# Supabase Postgres (direct connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase service role key (for admin operations, never expose to client)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin credentials
ADMIN_EMAIL=admin@agripredict.com
ADMIN_PASSWORD=Admin@2026
ADMIN_SECRET=AGRI2026

# JWT
JWT_SECRET_KEY=another-random-secret
JWT_EXPIRATION_HOURS=24

# CORS origin (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:3000
