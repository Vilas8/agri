# ============================================
# AgriPredict Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================

# ── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-string-32-chars-min

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # KEEP SECRET — never expose to browser

# Direct Postgres connection string (for SQLAlchemy / psycopg2 if needed)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Admin credentials (used by app.py admin login route) ────────────────────
ADMIN_EMAIL=admin@agripredict.com
ADMIN_PASSWORD=Admin@2026
ADMIN_SECRET=AGRI2026

# ── JWT (Flask-JWT or PyJWT — used for fallback auth) ───────────────────────
JWT_SECRET_KEY=another-random-secret-string-here
JWT_EXPIRATION_HOURS=24

# ── CORS ────────────────────────────────────────────────────────────────────
# Set to your actual frontend URL in production (no trailing slash)
CORS_ORIGIN=http://localhost:5500
# For Vercel: CORS_ORIGIN=https://agri-abc.vercel.app
