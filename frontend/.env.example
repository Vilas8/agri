# ============================================
# AgriPredict Frontend – Environment Variables
# Copy this file to env_injector.js (for plain HTML / local dev)
# OR set these as Vite env vars if using a build tool.
# NEVER commit your real keys to version control.
# ============================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here   # This is safe to expose in the browser

# ── Flask Backend ────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:5000

# ── For plain HTML (no build tool) ──────────────────────────────────────────
# Edit frontend/env_injector.js directly and fill in the values above.
# That file sets window.__AGRI_ENV__ which the rest of the app reads.
